# Copie este arquivo para .env.local e preencha com seus valores

# Token do Bot Telegram
# Obtenha em: https://t.me/BotFather (comando /newbot)
TELEGRAM_BOT_TOKEN=seu_token_aqui_123456789:ABCDEFGHijklmno

# (Opcional) Se usar Supabase para dados persistentes
# SUPABASE_URL=https://seu-proj.supabase.co
# SUPABASE_KEY=sua_chave_publica

# (Opcional) Se usar Redis para cache
# UPSTASH_REDIS_REST_URL=https://seu-redis.upstash.io
# UPSTASH_REDIS_REST_TOKEN=seu_token

# (Opcional) Se usar MongoDB
# MONGODB_URI=mongodb+srv://usuario:senha@cluster.mongodb.net/demo?retryWrites=true&w=majority
